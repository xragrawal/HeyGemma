<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gemma_bg">

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollHome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="120dp"
        android:clipToPadding="false"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="8dp">

            <!-- Date -->
            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:letterSpacing="0.18"
                android:textAllCaps="true"
                android:textColor="@color/gemma_ink_mute" />

            <!-- Greeting -->
            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textSize="38sp"
                android:textColor="@color/gemma_ink"
                android:lineSpacingMultiplier="1.0"
                android:letterSpacing="-0.01" />

            <!-- Stats -->
            <TextView
                android:id="@+id/tvStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textSize="13sp"
                android:textColor="@color/gemma_ink_mute"
                android:lineSpacingMultiplier="1.5"
                android:maxWidth="300dp" />

            <!-- Wake pill -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_wake_pill"
                android:paddingStart="8dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_circle_lime" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Listening for &quot;Hey Gemma&quot;"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.08"
                    android:textAllCaps="true"
                    android:textColor="@color/gemma_lime" />
            </LinearLayout>

            <!-- Space -->
            <Space android:layout_width="match_parent" android:layout_height="14dp" />

            <!-- Connected section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Connected"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.18"
                    android:textAllCaps="true"
                    android:textColor="@color/gemma_ink_faint" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● IMPORTANT ONLY"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.14"
                    android:textColor="@color/gemma_lime" />
            </LinearLayout>

            <!-- Space -->
            <Space android:layout_width="match_parent" android:layout_height="10dp" />

            <!-- Telegram tile -->
            <LinearLayout
                android:id="@+id/btnTelegram"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_surface_border_14"
                android:padding="14dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_telegram"
                    android:contentDescription="Telegram" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Telegram"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/gemma_ink"
                        android:letterSpacing="-0.005" />

                    <TextView
                        android:id="@+id/tvTelegramSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="All caught up"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.04"
                        android:textColor="@color/gemma_ink_mute" />
                </LinearLayout>

                <!-- Unread badge -->
                <TextView
                    android:id="@+id/tvTelegramUnread"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_unread_badge"
                    android:paddingStart="7dp"
                    android:paddingEnd="7dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="@color/gemma_bg"
                    android:visibility="gone" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron"
                    android:contentDescription="Open" />
            </LinearLayout>

            <!-- Space -->
            <Space android:layout_width="match_parent" android:layout_height="14dp" />

            <!-- "Today." section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/tvTodayHeader"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Today."
                        android:textSize="24sp"
                        android:textColor="@color/gemma_ink"
                        android:letterSpacing="-0.005" />

                    <TextView
                        android:id="@+id/tvTodoCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.16"
                        android:textAllCaps="true"
                        android:textColor="@color/gemma_ink_faint" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/gemma_line2" />
            </LinearLayout>

            <!-- Space -->
            <Space android:layout_width="match_parent" android:layout_height="10dp" />

            <!-- Todos RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTodos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <!-- Footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp"
                android:text="— END OF LIST —"
                android:gravity="center"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.16"
                android:textColor="@color/gemma_ink_faint" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Settings icon — top-right overlay -->
    <TextView
        android:id="@+id/btnProfile"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:text="⚙"
        android:textSize="20sp"
        android:textColor="@color/gemma_ink_mute"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true" />

    <!-- Bottom dock with gradient fade -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_fade">

        <!-- FAB mic button -->
        <FrameLayout
            android:id="@+id/btnRecord"
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:layout_gravity="center"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_circle_lime"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_mic"
                android:contentDescription="Record"
                android:tint="@color/gemma_bg" />
        </FrameLayout>
    </FrameLayout>

    <!-- Nav bar pill -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="horizontal">

        <View
            android:layout_width="120dp"
            android:layout_height="4dp"
            android:background="@drawable/bg_nav_bar_pill" />
    </LinearLayout>

</FrameLayout>

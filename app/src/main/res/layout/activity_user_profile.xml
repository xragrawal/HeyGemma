<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gemma_bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="32dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="56dp">

            <!-- ── Header ─────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="28dp">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="←"
                    android:textSize="22sp"
                    android:textColor="@color/gemma_ink_soft"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Profile"
                    android:textSize="26sp"
                    android:textColor="@color/gemma_ink"
                    android:letterSpacing="-0.01" />

                <TextView
                    android:id="@+id/tvProfileBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOT SET"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:textAllCaps="true"
                    android:letterSpacing="0.14"
                    android:textColor="@color/gemma_rose"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:background="@drawable/bg_rose_pill" />
            </LinearLayout>

            <!-- ── Your Name ──────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR NAME"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.16"
                android:textAllCaps="true"
                android:textColor="@color/gemma_ink_mute"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="22dp"
                android:background="@drawable/bg_surface_border_14"
                android:padding="14dp"
                android:textSize="15sp"
                android:textColor="@color/gemma_ink"
                android:hint="e.g. Jayesh"

                android:inputType="textPersonName"
                android:singleLine="true" />

            <!-- ── Emergency Keyword ──────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMERGENCY KEYWORD"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.16"
                android:textAllCaps="true"
                android:textColor="@color/gemma_ink_mute"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etKeyword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_border_14"
                android:padding="14dp"
                android:textSize="15sp"
                android:textColor="@color/gemma_ink"
                android:hint="e.g. emergency"

                android:inputType="text"
                android:singleLine="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="4dp"
                android:text="Say this word 3x in a row to trigger alert. Use 2+ syllable words for best recognition (e.g. emergency, mayday, rescue)."
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"
                android:textColor="@color/gemma_ink_mute" />

            <!-- ── Divider ─────────────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gemma_line2"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="18dp" />

            <!-- ── Emergency Contact ──────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMERGENCY CONTACT"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.16"
                android:textAllCaps="true"
                android:textColor="@color/gemma_ink_mute"
                android:layout_marginBottom="8dp" />

            <!-- Telegram username field -->
            <EditText
                android:id="@+id/etContactUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_border_14"
                android:padding="14dp"
                android:textSize="15sp"
                android:textColor="@color/gemma_ink"
                android:hint="@username or numeric chat ID"
                android:inputType="text"
                android:singleLine="true" />

            <EditText
                android:id="@+id/etManualName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_surface_border_14"
                android:padding="14dp"
                android:textSize="15sp"
                android:textColor="@color/gemma_ink"
                android:hint="Contact name (e.g. Jayesh)"
                android:inputType="textPersonName"
                android:singleLine="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Enter @username — the bot will resolve and verify it."
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"
                android:textColor="@color/gemma_ink_mute" />

            <!-- OR: pick from contacts who have already messaged the bot -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="6dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/gemma_line2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  OR PICK FROM BOT CONTACTS  "
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.14"
                    android:textColor="@color/gemma_ink_faint" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/gemma_line2" />
            </LinearLayout>

            <!-- Contact rows populated programmatically -->
            <LinearLayout
                android:id="@+id/llContacts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/tvContactsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No contacts yet. Have them message your bot first."
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textColor="@color/gemma_ink_faint"
                android:visibility="gone" />

            <!-- Resolution status badge -->
            <LinearLayout
                android:id="@+id/llSelectedContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_lime_surface"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="✓ Verified:"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/gemma_lime" />

                <TextView
                    android:id="@+id/tvSelectedName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/gemma_ink"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ── Divider ─────────────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gemma_line2"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="20dp" />

            <!-- ── Test Alert Button ──────────────────────────────────── -->
            <TextView
                android:id="@+id/btnTestAlert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_rose_pill_full"
                android:padding="14dp"
                android:text="Send Test Alert"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/gemma_ink"
                android:clickable="true"
                android:focusable="true" />

            <!-- ── Save Button ────────────────────────────────────────── -->
            <TextView
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_lime_btn"
                android:padding="16dp"
                android:text="Save Profile"
                android:gravity="center"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/gemma_bg"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gemma_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="10dp">

        <!-- Back button -->
        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_circle_surface2"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back"
                android:contentDescription="Back" />
        </FrameLayout>

        <!-- Avatar -->
        <FrameLayout
            android:id="@+id/ivChatAvatar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_circle_lime">

            <TextView
                android:id="@+id/tvChatInitials"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="?"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/gemma_bg" />
        </FrameLayout>

        <!-- Name + subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvChatName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/gemma_ink"
                    android:letterSpacing="-0.005"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_urgency_amber" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvChatSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IMPORTANT · last seen recently"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.06"
                android:textColor="@color/gemma_ink_mute" />
        </LinearLayout>

        <!-- Call button -->
        <FrameLayout
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_circle_surface2"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_phone"
                android:contentDescription="Call" />
        </FrameLayout>
    </LinearLayout>

    <!-- 1px separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gemma_line" />

    <!-- Gemma reading strip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_gemma_strip"
        android:layout_margin="10dp"
        android:padding="10dp">

        <FrameLayout
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_circle_lime">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_sparkle"
                android:tint="@color/gemma_bg"
                android:contentDescription="Gemma" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvGemmaStrip"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Gemma is reading this thread aloud at IMPORTANT priority."
            android:textSize="11sp"
            android:textColor="@color/gemma_ink_soft"
            android:lineSpacingMultiplier="1.4" />
    </LinearLayout>

    <!-- Messages list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp" />

    <!-- Composer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp">

        <!-- Plus button -->
        <FrameLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_circle_surface2"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_plus"
                android:contentDescription="Attach" />
        </FrameLayout>

        <!-- Pill text input -->
        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_composer_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:hint="Message…"
            android:textColorHint="@color/gemma_ink_mute"
            android:textColor="@color/gemma_ink"
            android:textSize="13sp"
            android:maxLines="1"
            android:inputType="textMultiLine|textCapSentences"
            android:gravity="center_vertical" />

        <!-- Mic send button -->
        <FrameLayout
            android:id="@+id/btnSend"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_circle_lime"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_mic"
                android:tint="@color/gemma_bg"
                android:contentDescription="Send" />
        </FrameLayout>
    </LinearLayout>

    <!-- Nav bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:gravity="center"
        android:orientation="horizontal">

        <View
            android:layout_width="120dp"
            android:layout_height="4dp"
            android:background="@drawable/bg_nav_bar_pill" />
    </LinearLayout>

</LinearLayout>
